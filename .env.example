# Render / Web app
PORT=10000
APP_BASE_URL=https://your-render-app.onrender.com
WORKER_TOKEN=change-this-long-random-token
MAX_IMAGES=5

# Local worker only
SERVER_URL=https://your-render-app.onrender.com
COMFY_URL=http://127.0.0.1:8188
COMFYUI_URL=http://127.0.0.1:8188
COMFY_INPUT_DIR=D:\Comfy-Desktop\ComfyUI-Shared\input
WORKFLOWS_API_DIR=./workflows_api
WORKER_POLL_MS=5000
DRY_RUN=true

# Image preprocessing before ComfyUI
# cover = keeps aspect ratio and centre-crops to selected canvas, no squeezing
# contain = keeps full image with transparent padding, no squeezing
IMAGE_FIT_MODE=cover

# Prompt AI / NVIDIA free endpoint
# Add these on Render if you want the Prompt AI button to work.
NVIDIA_API_KEY=your_nvidia_api_key_here
PROMPT_AI_BASE_URL=https://integrate.api.nvidia.com/v1
PROMPT_AI_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
PROMPT_AI_MAX_TOKENS=1200
